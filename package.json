{
  "name": "arth",
  "version": "0.1.0",
  "description": "Android Remote Terminal Host",
  "main": "index.js",
  "scripts": {
    "build:client": "esbuild src/client/index.tsx --bundle --outfile=dist/client/index.js --minify --define:process.env.NODE_ENV='\"production\"'",
    "build:server": "tsc",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "dev:server": "nodemon",
    "dev:client": "esbuild src/client/index.tsx --bundle --outfile=dist/client/index.js --sourcemap --watch",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@distube/ytdl-core": "^4.15.8",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "fs": "^0.0.1-security",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "styled-components": "^6.1.13",
    "yt-search": "^2.12.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
